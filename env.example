# Exemplo de variável de ambiente para a URL do banco de dados
# Substitua os valores abaixo pelos seus dados de conexão do PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Secret para o JWT (JSON Web Token) - Mude para uma string aleatória e segura
JWT_SECRET="SECRETO_SUPER_SEGURO_E_ALEATORIO"

# URL da sua aplicação, usada pelo NextAuth
NEXTAUTH_URL="http://localhost:3000"

# Um secret para o NextAuth, usado para assinar cookies e tokens.
# Você pode gerar um com: openssl rand -hex 32
NEXTAUTH_SECRET="SECRETO_DO_NEXTAUTH_GERADO_ALEATORIAMENTE" 